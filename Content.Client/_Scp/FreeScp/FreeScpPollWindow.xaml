<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               x:Class="Content.Client._Scp.FreeScp.FreeScpPollWindow"
               Title="{Loc free-scp-poll-window-title}">
    <BoxContainer Orientation="Vertical">
        <Label Name="BodyLabel" />
        <BoxContainer Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Name="AcceptButton" Access="Public" />
            <Control MinSize="20 0" />
            <Button Name="DeclineButton" Access="Public" />
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
